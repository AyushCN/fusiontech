{
  "name": "vscode-anchor",
  "displayName": "YamlAnchor",
  "description": "Visual CI/CD pipeline management for YamlAnchor — run, debug, and inspect anchor.yaml jobs directly from VS Code.",
  "version": "0.1.0",
  "publisher": "AyushCN",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Testing"],
  "keywords": ["yaml", "ci", "github-actions", "dagger", "pipeline"],
  "icon": "images/icon.png",
  "activationEvents": [
    "onLanguage:yaml",
    "workspaceContains:anchor.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yamlanchor.runJob",
        "title": "⚓ Run Job Locally",
        "category": "YamlAnchor"
      },
      {
        "command": "yamlanchor.scanSecrets",
        "title": "🔐 Scan for Secrets",
        "category": "YamlAnchor"
      },
      {
        "command": "yamlanchor.generate",
        "title": "⚙️ Generate GitHub Actions YAML",
        "category": "YamlAnchor"
      },
      {
        "command": "yamlanchor.openExec",
        "title": "🐚 Open Interactive Shell",
        "category": "YamlAnchor"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceFilename == anchor.yaml",
          "command": "yamlanchor.runJob",
          "group": "yamlanchor"
        },
        {
          "when": "resourceFilename == anchor.yaml",
          "command": "yamlanchor.scanSecrets",
          "group": "yamlanchor"
        }
      ]
    },
    "configuration": {
      "title": "YamlAnchor",
      "properties": {
        "yamlanchor.anchorPath": {
          "type": "string",
          "default": "anchor",
          "description": "Path to the anchor binary."
        },
        "yamlanchor.configFile": {
          "type": "string",
          "default": "anchor.yaml",
          "description": "Path to your anchor.yaml config file."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  }
}
